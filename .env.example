# IP ou nom d'hôte du serveur : Caddy génère le certificat HTTPS pour cette
# adresse. Indispensable pour accéder à l'app depuis un autre appareil.
LIVEFLOW_HOST=192.168.1.16

# Identifiants de connexion à l'interface (admin/admin par défaut).
LIVEFLOW_USER=admin
LIVEFLOW_PASSWORD=admin

# Code langue ISO forcé pour la transcription ("fr", "en"...).
# Laisser vide pour la détection automatique de la langue.
ASR_LANGUAGE=

# Clé API transmise au moteur ASR (sans importance en local).
ASR_API_KEY=sk-local

# Jeton Hugging Face, seulement si le téléchargement du modèle l'exige.
HF_TOKEN=
